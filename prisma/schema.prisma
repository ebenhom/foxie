generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["queryCompiler"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  name String?

  email String @unique

  image String?

  role String @default("USER")

  comments Comment[]

  favorites Favorite[]

  histories History[]

  createdAt DateTime @default(now())
}

model Novel {

  id String @id @default(cuid())


  title String


  cover String


  description String


  tags String


  category String @default("Khác")


  views Int @default(0)


  createdAt DateTime @default(now())


  chapters Chapter[]


  favorites Favorite[]


  comments Comment[]


  histories History[]

}

model Chapter {
  id String @id @default(cuid())

  title String

  content String

  images String[]

  novelId String

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  histories History[]

  createdAt DateTime @default(now())
}

model Comment {
  id String @id @default(cuid())

  text String

  userId String

  novelId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Favorite {
  id String @id @default(cuid())

  userId String

  novelId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, novelId])
}

model History {
  id String @id @default(cuid())

  userId String

  novelId String

  chapterId String

  progress Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([userId, chapterId])
}